{
  "extends": "@bassist/tsconfig/web.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "types": ["vite/client", "node", "vitest/globals"],
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "test/**/*.ts",
    "docs/.vitepress/**/*.ts",
    "docs/**/*.ts",
    "docs/**/*.tsx",
    "docs/**/*.vue",
    "docs/**/*.md"
  ],
  "exclude": ["node_modules", "dist", "lib"]
}
